{
  "name": "personal-blog",
  "description": "Personal blog powered by Next.js and original Quartz rendering",
  "private": true,
  "version": "4.5.2",
  "type": "module",
  "author": "jackyzha0 <j.zhao2k19@gmail.com>",
  "license": "GPL-3.0-only",
  "homepage": "https://quartz.jzhao.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/jackyzha0/quartz.git"
  },
  "scripts": {
    "quartz": "./quartz/bootstrap-cli.mjs",
    "quartz:build:site": "node quartz/bootstrap-cli.mjs build -o public/blog",
    "dev": "npm run quartz:build:site && next dev",
    "build": "npm run quartz:build:site && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "legacy:quartz:build": "node quartz/bootstrap-cli.mjs build",
    "legacy:quartz:dev": "node quartz/bootstrap-cli.mjs build --serve",
    "docs": "node quartz/bootstrap-cli.mjs build --serve -d docs",
    "sync:obsidian": "node scripts/obsidian-sync.mjs",
    "sync:obsidian:check": "node scripts/obsidian-sync.mjs --check",
    "sync:obsidian:dry": "node scripts/obsidian-sync.mjs --dry-run",
    "sync:obsidian:init": "node scripts/obsidian-sync.mjs --init-from-content",
    "sync:obsidian:review": "node scripts/obsidian-sync.mjs --review",
    "sync:obsidian:review:all": "node scripts/obsidian-sync.mjs --review --all",
    "check": "tsc --noEmit && npx prettier . --check",
    "format": "npx prettier . --write",
    "test": "tsx --test",
    "profile": "0x -D prof ./quartz/bootstrap-cli.mjs build --concurrency=1"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10.9.2"
  },
  "keywords": [
    "site generator",
    "ssg",
    "digital-garden",
    "markdown",
    "blog",
    "quartz"
  ],
  "bin": {
    "quartz": "./quartz/bootstrap-cli.mjs"
  },
